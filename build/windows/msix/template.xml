<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="mercury"
        Arguments=""
        InstallLocation="C:\Program Files\Mercury\Mercury">
    </Installer>
    <PackageInformation
        PackageName="Mercury"
        PackageDisplayName="Mercury"
        PublisherName="CN=Mercury"
        PublisherDisplayName="Mercury"
        Version="0.1.0.0"
        PackageDescription="LAN Clipboard & File Sharing">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.mercury.app"
                Description="LAN Clipboard & File Sharing"
                DisplayName="Mercury"
                ExecutableName="mercury"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Mercury</DisplayName>
            <PublisherDisplayName>Mercury</PublisherDisplayName>
            <Description>LAN Clipboard & File Sharing</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="mercury.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
